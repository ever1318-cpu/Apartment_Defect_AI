{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apartment-defect-ai.local/schemas/deployment_profiles.schema.json",
  "title": "Model Deployment Profiles",
  "type": "object",
  "required": ["version", "profiles"],
  "properties": {
    "version": {"type": "string"},
    "profiles": {
      "type": "object",
      "required": ["cpu", "gpu"],
      "additionalProperties": {
        "type": "object",
        "required": ["name", "execution_providers", "expected_batch_size", "latency_target_ms", "settings"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "execution_providers": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "expected_batch_size": {"type": "integer", "minimum": 1},
          "latency_target_ms": {"type": ["number", "null"], "exclusiveMinimum": 0},
          "settings": {"type": "object"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
