{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apartment-defect-ai.local/schemas/dataset_version_manifest.schema.json",
  "title": "Field Dataset Version Manifest",
  "type": "object",
  "required": ["format_version", "dataset_version", "created_at", "seed", "privacy_mode", "source_batches", "included_count", "excluded", "split_counts", "label_distribution", "quality_distribution", "records_file", "annotations_file", "lineage"],
  "properties": {
    "format_version": {"const": "1.0"},
    "dataset_version": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "seed": {"type": "integer"},
    "privacy_mode": {"enum": ["raw", "masked"]},
    "source_batches": {"type": "array", "items": {"type": "string"}},
    "included_count": {"type": "integer", "minimum": 0},
    "excluded": {"type": "array", "items": {"type": "object", "required": ["image_id", "reason"], "properties": {"image_id": {"type": "string"}, "reason": {"type": "string"}}, "additionalProperties": false}},
    "split_counts": {"type": "object", "required": ["train", "validation", "test"], "properties": {"train": {"type": "integer"}, "validation": {"type": "integer"}, "test": {"type": "integer"}}, "additionalProperties": false},
    "label_distribution": {"type": "object", "additionalProperties": {"type": "integer"}},
    "quality_distribution": {"type": "object", "additionalProperties": {"type": "integer"}},
    "records_file": {"const": "records.jsonl"},
    "annotations_file": {"const": "annotations.jsonl"},
    "lineage": {"type": "object", "required": ["ingestion_directory", "annotation_directory"], "properties": {"ingestion_directory": {"type": "string"}, "annotation_directory": {"type": "string"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
