{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apartment-defect-ai.local/schemas/service_metrics.schema.json",
  "title": "In-memory Service Metrics",
  "type": "object",
  "required": ["request_count", "success_count", "error_count", "batch_request_count", "image_count", "model_load_count", "model_load_failure_count", "cache_hit_count", "cache_miss_count", "model_reload_count", "model_reload_failure_count", "request_rejection_count", "timeout_count", "inference_duration", "request_duration", "by_model", "by_error_type", "by_response_status", "batch_size_buckets", "readiness_state", "active_model_name", "active_model_version", "session_cache_size", "inference_cache_size", "concurrent_requests", "process_start_time", "uptime_seconds"],
  "properties": {
    "request_count": {"type": "integer", "minimum": 0},
    "success_count": {"type": "integer", "minimum": 0},
    "error_count": {"type": "integer", "minimum": 0},
    "batch_request_count": {"type": "integer", "minimum": 0},
    "image_count": {"type": "integer", "minimum": 0},
    "model_load_count": {"type": "integer", "minimum": 0},
    "model_load_failure_count": {"type": "integer", "minimum": 0},
    "cache_hit_count": {"type": "integer", "minimum": 0},
    "cache_miss_count": {"type": "integer", "minimum": 0},
    "model_reload_count": {"type": "integer", "minimum": 0},
    "model_reload_failure_count": {"type": "integer", "minimum": 0},
    "request_rejection_count": {"type": "integer", "minimum": 0},
    "timeout_count": {"type": "integer", "minimum": 0},
    "inference_duration": {"$ref": "#/$defs/duration"},
    "request_duration": {"$ref": "#/$defs/duration"},
    "by_model": {"type": "object", "additionalProperties": {"type": "integer"}},
    "by_error_type": {"type": "object", "additionalProperties": {"type": "integer"}},
    "by_response_status": {"type": "object", "additionalProperties": {"type": "integer"}},
    "batch_size_buckets": {"type": "object", "additionalProperties": {"type": "integer"}},
    "readiness_state": {"type": "boolean"},
    "active_model_name": {"type": ["string", "null"]},
    "active_model_version": {"type": ["string", "null"]},
    "session_cache_size": {"type": "integer", "minimum": 0},
    "inference_cache_size": {"type": "integer", "minimum": 0},
    "concurrent_requests": {"type": "integer", "minimum": 0},
    "process_start_time": {"type": "number"},
    "uptime_seconds": {"type": "number", "minimum": 0}
  },
  "$defs": {
    "duration": {
      "type": "object",
      "required": ["count", "sum", "min", "max"],
      "properties": {
        "count": {"type": "integer", "minimum": 0},
        "sum": {"type": "number", "minimum": 0},
        "min": {"type": ["number", "null"]},
        "max": {"type": ["number", "null"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
