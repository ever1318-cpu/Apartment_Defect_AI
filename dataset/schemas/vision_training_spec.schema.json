{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apartment-defect-ai.local/schemas/vision_training_spec.schema.json",
  "title": "Vision Training Specification",
  "type": "object",
  "required": [
    "dataset_version",
    "tasks",
    "split_paths",
    "label_mapping_path",
    "image_preprocessing",
    "augmentation",
    "batch_size",
    "epochs",
    "learning_rate",
    "random_seed",
    "output_directory",
    "model_artifact_name"
  ],
  "properties": {
    "dataset_version": {"type": "string", "minLength": 1},
    "tasks": {"type": "object"},
    "split_paths": {
      "type": "object",
      "required": ["train", "validation", "test"],
      "properties": {
        "train": {"type": "string", "minLength": 1},
        "validation": {"type": "string", "minLength": 1},
        "test": {"type": "string", "minLength": 1}
      }
    },
    "label_mapping_path": {"type": "string", "minLength": 1},
    "image_preprocessing": {"type": "object"},
    "augmentation": {"type": "object"},
    "batch_size": {"type": "integer", "minimum": 1},
    "epochs": {"type": "integer", "minimum": 1},
    "learning_rate": {"type": "number", "exclusiveMinimum": 0},
    "random_seed": {"type": "integer"},
    "output_directory": {"type": "string", "minLength": 1},
    "model_artifact_name": {"type": "string", "minLength": 1}
  }
}
