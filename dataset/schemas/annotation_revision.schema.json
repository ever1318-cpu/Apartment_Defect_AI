{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apartment-defect-ai.local/schemas/annotation_revision.schema.json",
  "title": "Annotation Revision",
  "type": "object",
  "required": ["annotation", "status", "annotator", "reviewer", "confidence", "notes", "revision", "created_at", "updated_at", "rejected_reason", "audit_history"],
  "properties": {
    "annotation": {"$ref": "vision_ground_truth.schema.json"},
    "status": {"enum": ["submitted", "approved", "rejected"]},
    "annotator": {"type": "string"},
    "reviewer": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "notes": {"type": "string"},
    "revision": {"type": "integer", "minimum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "rejected_reason": {"type": ["string", "null"]},
    "audit_history": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": false
}
